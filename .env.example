# Local Postgres example:
# DATABASE_URL=postgres://radio_tracker:radio_tracker@localhost:5432/radio_tracker

# Supabase Postgres example. Use the connection string from Project Settings > Database.
# Keep sslmode=require for Supabase connections.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=[YOUR-SUPABASE-PUBLISHABLE-KEY]
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CONTACT_EMAIL=hello@example.com
POLL_ONCE=false
